rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Вспомогательные функции ────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Получаем роль напрямую
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isAuth() && getUserRole() == 'super_admin';
    }

    // ─── users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuth(); // Разрешаем всем залогиненным видеть профили (нужно для имен в ивентах)
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'managedClubId'])
                    || isSuperAdmin();
      allow delete: if false;
    }

    // ─── clubs ────────────────────────────────────────────────────────────────

    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSuperAdmin();
      allow update: if isAuth() && (
        resource.data.get('ownerId', '') == request.auth.uid ||
        isSuperAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
      );
      allow delete: if isSuperAdmin();

      match /followers/{followerId} {
        allow read: if true;
        allow write: if isOwner(followerId);
      }
    }

    // ─── events ───────────────────────────────────────────────────────────────

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuth() && (getUserRole() == 'club_admin' || isSuperAdmin());
      allow update: if isAuth() && (
        resource.data.get('clubId', '') == request.auth.uid ||
        isSuperAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['participants', 'currentParticipants'])
      );
      allow delete: if isAuth() && (
        resource.data.get('clubId', '') == request.auth.uid ||
        isSuperAdmin()
      );
    }

    // ─── club_applications ───────────────────────────────────────────────────

    match /club_applications/{appId} {
      // Упрощаем чтение для админов и владельцев
      allow read: if isAuth(); 
      
      allow create: if isAuth();
      
      allow update: if isSuperAdmin() || (
        isOwner(resource.data.userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notified'])
      );
      
      allow delete: if isSuperAdmin();
    }
  }
}
